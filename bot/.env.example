# --- Mattermost-бот (mmpy_bot) → n8n ---

MM_BASE_URL=https://chat.skbkontur.ru
MM_PORT=443
MM_TEAM=Kontur

# Токен бота Mattermost. НЕ коммитить.
MM_BOT_TOKEN=

# Входящий вебхук n8n.
# Тест-режим ноды:  https://n8n-common.testkontur.ru/webhook-test/mattermost-in
# После активации:  https://n8n-common.testkontur.ru/webhook/mattermost-in
N8N_WEBHOOK_URL=https://n8n-common.testkontur.ru/webhook/mattermost-in

# Внутренний CA — обычно нужно false
MM_SSL_VERIFY=false

DEBUG=true
