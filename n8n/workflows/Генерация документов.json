    {
      "parameters": {
        "jsCode": "const base = $('Значения документов').first().json;\nlet smart = {};\ntry {\n  const resp = $input.first().json.response || '{}';\n  const m = resp.match(/\\{[\\s\\S]*\\}/);\n  smart = JSON.parse(m ? m[0] : resp);\n} catch (e) { smart = {}; }\nreturn [{ json: {\n  ...base,\n  фио_работника_род: smart['фио_работника_род'] || base['фио_работника'],\n  обстоятельства: smart['обстоятельства'] || '[УТОЧНИТЬ]',\n  приложения: smart['приложения'] || 'Отсутствуют',\n} }];\n"
      },
