      "position": [
        3296,
        2608
      ]
    },
    {
      "parameters": {
        "jsCode": "// VISION STUB v1 — TODO: заменить на HTTP Request к vision-модели Ollama (qwen2-vl / llava)\n// Интерфейс: принимает evidenceDescription, возвращает { vision_stub, analysis }\n// При замене: убрать этот нод, добавить HTTP Request к http://127.0.0.1:11434/api/generate\n// с моделью qwen2-vl и base64-изображением в поле images[]\nconst d = $input.first().json;\nconst desc = d.context?.evidenceDescription || 'Доказательства не предоставлены';\nreturn [{ json: {\n  ...d,\n  vision_analysis: {\n    vision_stub: true,\n    analysis: desc,\n    _note: 'STUB: заменить на реальную vision-модель Ollama'\n  }\n} }];"
      },
      "id": "df7914d3-c67b-4bef-915c-5654e7d216ac",
      "name": "Vision: анализ доказательств (заглушка)1",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        3520,
        2464
      ]
