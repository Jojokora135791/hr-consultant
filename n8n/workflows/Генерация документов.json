    {
      "parameters": {
        "jsCode": "// TODO: добавить knowledge-файлы и убрать эту заглушку\n// Инструкция в sticky note «Добавить новый сценарий» (см. выше)\nconst d = $input.first().json;\nconst scenario = d.context?.scenario || 'unknown';\nreturn [{ json: {\n  ...d,\n  checklist_content: `[ЗАГЛУШКА] Сценарий \"${scenario}\" не реализован. Добавьте knowledge/${scenario}_checklist.md`\n} }];"
      },
      "id": "e8e825e4-1ab4-4db4-afe7-b218b24f6145",
      "name": "Сценарий: заглушка1",
      "type": "n8n-nodes-base.code",
