      "parameters": {
        "jsCode": "const d = $('ДАТЫ: объединить с результатом проверки').item.json;\nconst reason = d.expiredReason === 'violation_date'\n  ? `Срок со дня нарушения (${d.violationDate}) истёк ${d.violationDeadline}`\n  : `Срок с момента обнаружения (${d.discoveryDate}) истёк ${d.discoveryDeadline}`;\nreturn [{ json: { output: `К сожалению, сроки привлечения к дисциплинарной ответственности истекли.\\n\\n${reason}.\\n\\nПо ТК РФ ст.193 применить взыскание уже невозможно.\\n\\nРекомендую обратиться к эксперту кадрового учёта — Касмыниной О. или Черепановой Т.` } }];"
