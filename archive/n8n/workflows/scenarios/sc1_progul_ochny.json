    {
      "id": "sc1-dates-prompt",
      "name": "ДАТЫ: сформировать промпт с историей",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        460,
        -80
      ],
      "parameters": {
        "jsCode": "const { sessionId, userMessage, history } = $input.first().json;\nconst systemPrompt = `Ты — HR-ассистент. Проверяем сроки привлечения к дисциплинарной ответственности по ТК РФ ст.193.\n\nДва ограничения (нарушение хотя бы одного → взыскание невозможно):\n1. Взыскание нельзя применить позднее 6 мес. со дня проступка (практически — 5 мес. 15 дней)\n2. Взыскание нельзя применить позднее 1 мес. со дня обнаружения (практически — 20 кал. дней)\n\nТвоя задача: запросить ДВЕ даты:\n1. Когда произошло нарушение\n2. Когда руководитель об этом узнал\n\nКогда обе даты названы — добавь в конец ответа ОТДЕЛЬНОЙ строкой:\nDATE_DATA: {\"violation\": \"YYYY-MM-DD\", \"discovery\": \"YYYY-MM-DD\"}\nЕсли дату невозможно распознать — null. Если даты ещё не названы — не добавляй DATE_DATA.`;\nconst messages = [{ role: 'system', content: systemPrompt }, ...history, { role: 'user', content: userMessage }];\nreturn [{ json: { sessionId, userMessage, messages, rag_topic: 'check_dates' } }];"
      }
    },
    {
      "id": "sc1-dates-llm",
      "name": "ДАТЫ: вызвать LLM",
      "type": "n8n-nodes-base.executeWorkflow",
      "typeVersion": 1.2,
      "position": [
        680,
        -80
      ],
      "parameters": {
        "source": "database",
        "workflowId": {
