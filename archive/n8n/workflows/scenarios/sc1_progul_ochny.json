      "id": "sc1-start-prompt",
      "name": "СТАРТ: сформировать промпт",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        460,
        -280
      ],
      "parameters": {
        "jsCode": "const { sessionId, userMessage } = $input.first().json;\nconst systemPrompt = `Ты — HR-ассистент для руководителей компании «Контур». Помогаешь оформить дисциплинарные документы.\n\nЧто умею:\n- Проверить сроки привлечения к ответственности по ТК РФ\n- Определить тип нарушения\n- Оформить акт об отсутствии и служебную записку\n\nГраница: до передачи пакета документов эксперту включительно. Решение о взыскании — только кадровый эксперт (Черепанова Т., Касмынина О.).\n\nПравила поведения:\n- Только факты от руководителя, ничего не додумываю\n- Если ситуация нестандартная — направляю к эксперту\n- Тон: деловой, на «вы», кратко\n\nПоздоровайся, коротко объясни что умеешь, попроси описать ситуацию (что случилось, с кем, когда примерно).`;\nreturn [{ json: { sessionId, userMessage, messages: [{ role: 'system', content: systemPrompt }, { role: 'user', content: userMessage }], rag_topic: 'progul' } }];"
      }
    },
