    {
      "id": "sc1-dates-parse",
      "name": "ДАТЫ: извлечь даты из ответа LLM",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        900,
        -80
      ],
      "parameters": {
        "jsCode": "const responseText = $input.first().json.response;\nconst trigger = $('Вызов из роутера').item.json;\nconst match = responseText.match(/DATE_DATA:\\s*(\\{[^}]+\\})/);\nlet datesFound = false, violationDate = null, discoveryDate = null;\nlet cleanResponse = responseText;\nif (match) {\n  try {\n    const d = JSON.parse(match[1]);\n    violationDate = d.violation;\n    discoveryDate = d.discovery;\n    datesFound = !!(violationDate && discoveryDate && violationDate !== 'null' && discoveryDate !== 'null');\n    cleanResponse = responseText.replace(/DATE_DATA:[\\s\\S]*$/, '').trim();\n  } catch(e) {}\n}\nreturn [{ json: { sessionId: trigger.sessionId, userMessage: trigger.userMessage, responseText: cleanResponse, datesFound, violationDate, discoveryDate } }];"
      }
    },
