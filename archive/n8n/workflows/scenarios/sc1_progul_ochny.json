    {
      "id": "sc1-expired-save",
      "name": "ПРОСРОЧЕНО: PostgreSQL — сохранить, state → EXPIRED",
      "type": "n8n-nodes-base.postgres",
      "typeVersion": 2.5,
      "position": [
        2000,
        -280
      ],
      "parameters": {
        "operation": "executeQuery",
        "query": "WITH su AS (INSERT INTO messages (session_id, role, content) VALUES ('{{ $json.sessionId }}', 'user', '{{ $json.userMessage.replace(/'/g, \"''\") }}') RETURNING id), sa AS (INSERT INTO messages (session_id, role, content) VALUES ('{{ $json.sessionId }}', 'assistant', 'Сроки привлечения к ответственности истекли. Обратитесь к эксперту кадрового учёта.') RETURNING id) UPDATE sessions SET state='EXPIRED', context=context || jsonb_build_object('violation_date','{{ $json.violationDate }}','discovery_date','{{ $json.discoveryDate }}','expired_reason','{{ $json.expiredReason || ''unknown'' }}') WHERE session_id='{{ $json.sessionId }}' RETURNING state",
