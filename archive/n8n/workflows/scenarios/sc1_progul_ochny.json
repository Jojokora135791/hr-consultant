      "id": "sc1-start-save",
      "name": "СТАРТ: PostgreSQL — сохранить, state → CHECK_DATES",
      "type": "n8n-nodes-base.postgres",
      "typeVersion": 2.5,
      "position": [
        900,
        -280
      ],
      "parameters": {
        "operation": "executeQuery",
        "query": "WITH su AS (INSERT INTO messages (session_id, role, content) VALUES ('{{ $('СТАРТ: сформировать промпт').item.json.sessionId }}', 'user', '{{ $('СТАРТ: сформировать промпт').item.json.userMessage.replace(/'/g, \"''\") }}') RETURNING id), sa AS (INSERT INTO messages (session_id, role, content) VALUES ('{{ $('СТАРТ: сформировать промпт').item.json.sessionId }}', 'assistant', '{{ $json.response.replace(/'/g, \"''\") }}') RETURNING id) UPDATE sessions SET state='CHECK_DATES' WHERE session_id='{{ $('СТАРТ: сформировать промпт').item.json.sessionId }}' RETURNING state",
        "options": {}
      },
      "credentials": {
        "postgres": {
          "id": "REPLACE_ME",
          "name": "hr_assistant PostgreSQL"
        }
