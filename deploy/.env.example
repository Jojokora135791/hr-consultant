# Скопируй в .env на сервере и заполни. .env в git НЕ коммитим (см. .gitignore).
# Секреты Anthropic / Telegram / Google Drive здесь НЕ нужны — их вводишь в n8n UI.

# Домен (A-запись → IP VPS). Пример: hr-kontur.xyz или hr-kontur.duckdns.org
DOMAIN=

# Postgres (бизнес-БД hr_assistant). Пароль придумай длинный.
POSTGRES_USER=hr
POSTGRES_PASSWORD=

# Часовой пояс
TZ=Asia/Yerevan
